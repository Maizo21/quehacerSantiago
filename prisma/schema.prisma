generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Idea {
  id          String    @id @default(uuid())
  titulo      String
  descripcion String?
  ubicacion   String
  imagenUrl   String?
  fecha       DateTime?
  destacado   Boolean   @default(false)
  creadoPor   String?
  creadoEl    DateTime  @default(now())
  tags        IdeaTag[]
  realizados  PlanRealizado[]
}

model Tag {
  id     String    @id @default(uuid())
  nombre String    @unique
  ideas  IdeaTag[]
}

model IdeaTag {
  ideaId String
  tagId  String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ideaId, tagId])
}

model PlanRealizado {
  id        String   @id @default(uuid())
  userId    String
  ideaId    String?
  titulo    String
  ubicacion String
  fecha     DateTime
  foto      String?
  nota      String?
  creadoEl  DateTime @default(now())
  idea      Idea?    @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  @@unique([userId, ideaId])
  @@index([userId, fecha])
}
